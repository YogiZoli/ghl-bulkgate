# ===========================================================================
# ghl-bulkgate — environment configuration
# Copy to ".env" for local dev. On Railway set these as service variables.
# ===========================================================================

# --- GHL Marketplace app (PUBLIC app) OAuth credentials ---
# From https://marketplace.gohighlevel.com -> your app -> Settings / Auth
GHL_CLIENT_ID=replace-me
GHL_CLIENT_SECRET=replace-me
# Must EXACTLY match the redirect URL registered in the Marketplace app:
GHL_REDIRECT_URI=https://your-app.up.railway.app/oauth/callback

# GHL API base + version header (conversations endpoints use 2021-04-15)
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-04-15

# Conversation Provider ID.
# - "Replace default SMS provider" model: NOT required (leave blank).
# - "Add new conversation channel" model (checkbox ticked): REQUIRED.
# This is a global fallback; a per-location value in the DB overrides it.
GHL_CONVERSATION_PROVIDER_ID=

# Status written back to GHL when Bulkgate ACCEPTS the message (before the
# DLR arrives). "accepted" is NOT delivery — Bulkgate can accept and the
# carrier can still silently drop (support ticket HZL-CTQKD-699). Keep this
# "pending"; the DLR callback sets delivered/failed.
# Valid GHL values: delivered | failed | pending | read
GHL_STATUS_ON_ACCEPT=pending

# Public base URL of this service (Railway URL). Used for the per-install
# inbound webhook URL shown after OAuth. Optional — falls back to deriving
# it from GHL_REDIRECT_URI.
PUBLIC_BASE_URL=

# --- Encryption: 32-byte url-safe base64 Fernet key ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-me

# --- Storage ---
# SQLite path (MVP). On Railway, point at a persistent volume mount.
DATABASE_PATH=./ghl_bulkgate.db

# --- Bulkgate defaults (per-location values in DB take precedence) ---
# Promotional is the field-proven default (VoxFlow live tests) and available
# on every Bulkgate account. Transactional requires the Transactional module
# enabled on the installer's account. Switch here if needed:
#   https://portal.bulkgate.com/api/2.0/advanced/transactional
BULKGATE_API_URL=https://portal.bulkgate.com/api/2.0/advanced/promotional
# Default country (ISO 3166-1 alpha-2). Used to expand local numbers.
DEFAULT_COUNTRY=hu
# Default sender type. gSystem is the safe default — Hungarian carriers do
# NOT support text sender IDs (gText); such sends are silently dropped even
# though the API replies "accepted". Only use gText per-install for countries
# that support it, with a whitelisted name (max 11 chars, alphanumeric).
DEFAULT_SENDER_ID=gSystem
# Sender name used only when sender type is gText.
DEFAULT_SENDER_ID_VALUE=
# Unicode handling: "never" (default) forces unicode=false so Bulkgate
# transliterates accents (ő→o) and GSM-7 pricing is kept (cost protection);
# "auto" sets the unicode flag from real GSM-7 detection.
UNICODE_MODE=never

# --- App ---
LOG_LEVEL=INFO
PORT=8080
